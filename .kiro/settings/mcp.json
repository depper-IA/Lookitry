{
  "mcpServers": {
    "hostinger": {
      "command": "npx",
      "args": ["-y", "@hostinger/api-mcp-server"],
      "env": {
        "HOSTINGER_API_KEY": "***REMOVED-SECRET***"
      },
      "disabled": false,
      "autoApprove": []
    },
    "n8n": {
      "command": "npx",
      "args": ["-y", "n8n-mcp@latest"],
      "env": {
        "N8N_API_URL": "https://n8n.wilkiedevs.com/api/v1",
        "N8N_API_KEY": "***REMOVED-SECRET***"
      },
      "disabled": false,
      "autoApprove": []
    }
  }
}
