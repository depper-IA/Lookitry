{
  "name": "sammy-agent",
  "version": "1.0.0",
  "description": "Sammy - Orchestrator agent for Lookitry",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:listener": "tsx local-scripts/listener.ts",
    "docker:build": "docker build -t sammy-agent .",
    "docker:run": "docker run --env-file .env.production sammy-agent"
  },
  "keywords": ["agent", "orchestrator", "telegram", "llm"],
  "author": "Lookitry",
  "license": "MIT",
  "dependencies": {
    "grammy": "^1.24.1",
    "groq-sdk": "^0.7.0",
    "better-sqlite3": "^11.8.1",
    "zod": "^3.24.1",
    "dotenv": "^16.4.7",
    "axios": "^1.7.9",
    "@supabase/supabase-js": "^2.49.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.6",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}