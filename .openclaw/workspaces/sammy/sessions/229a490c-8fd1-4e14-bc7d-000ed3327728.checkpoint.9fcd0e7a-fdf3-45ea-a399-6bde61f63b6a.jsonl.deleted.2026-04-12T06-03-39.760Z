{"type":"message","id":"855e76f4","parentId":"daad76a0","timestamp":"2026-04-12T01:09:28.771Z","message":{"role":"toolResult","toolCallId":"call_function_fbiumtxhh4n8_1","toolName":"exec","content":[{"type":"text","text":"'use client';\n\nimport { useMemo } from 'react';\nimport DOMPurify from 'dompurify';\n\ntype Props = {\n  html: string;\n  className?: string;\n};\n\nexport default function SanitizedHtml({ html, className }: Props) {\n  const cleanHtml = useMemo(() => {\n    if (typeof window === 'undefined') return html;\n    return DOMPurify.sanitize(html, {\n      ALLOWED_TAGS: [\n        'p', 'br', 'strong', 'em', 'u', 's', 'a', 'ul', 'ol', 'li',\n        'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'blockquote', 'code', 'pre',\n        'img', 'figure', 'figcaption', 'table', 'thead', 'tbody', 'tr', 'th', 'td',\n        'span', 'div', 'hr', 'abbr', 'sub', 'sup', 'del', 'ins', 'mark',\n        'video', 'audio', 'source', 'iframe',\n      ],\n      ALLOWED_ATTR: [\n        'href', 'title', 'target', 'rel', 'src', 'alt', 'width', 'height',\n        'class', 'id', 'style', 'loading', 'referrerpolicy', 'allow', 'allowfullscreen',\n        'controls', 'autoplay', 'loop', 'muted', 'playsinline',\n      ],\n      ALLOWED_URI_REGEXP: /^(?:(?:(?:f|ht)tps?|mailto|tel|callto|cid|xmpp):|[^a-z]|[a-z+.]+(?:[^a-z+.]+|$))/i,\n    });\n  }, [html]);\n\n  return <div className={className} dangerouslySetInnerHTML={{ __html: cleanHtml }} />;\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":13,"aggregated":"'use client';\n\nimport { useMemo } from 'react';\nimport DOMPurify from 'dompurify';\n\ntype Props = {\n  html: string;\n  className?: string;\n};\n\nexport default function SanitizedHtml({ html, className }: Props) {\n  const cleanHtml = useMemo(() => {\n    if (typeof window === 'undefined') return html;\n    return DOMPurify.sanitize(html, {\n      ALLOWED_TAGS: [\n        'p', 'br', 'strong', 'em', 'u', 's', 'a', 'ul', 'ol', 'li',\n        'h1', 'h2', 'h3', 'h4', 'h5