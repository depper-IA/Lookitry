{"type":"message","id":"41d2c0ed","parentId":"2f439d1a","timestamp":"2026-04-12T22:58:27.202Z","message":{"role":"toolResult","toolCallId":"call_function_bzgazie7xudy_1","toolName":"exec","content":[{"type":"text","text":"export function TemplateEditorial({ brandSlug, brand, products, footerUrl, isPreview = false }: { brandSlug: string; brand: BrandData; products: ProductData[]; footerUrl?: string; isPreview?: boolean }) {\r\n  const primary = brand.social_links?._landing_primary || brand.primary_color || '#111111';\r\n  const secondary = brand.social_links?._landing_secondary || primary;\r\n  const [selectedId, setSelectedId] = useState<string | null>(products && products.length > 0 ? products[0].id : null);\r\n\r\n  const socialLinks = brand.social_links || {};\r\n  const entries = getVisibleSocialEntries(socialLinks);\r\n  const socialIcons: Record<string, React.ReactNode> = {\r\n    instagram: <InstagramIcon className=\"w-3.5 h-3.5\" />,\r\n    facebook:  <FacebookIcon  className=\"w-3.5 h-3.5\" />,\r\n    tiktok:    <TikTokIcon    className=\"w-3.5 h-3.5\" />,\r\n    youtube:   <YouTubeIcon   className=\"w-3.5 h-3.5\" />,\r\n    x:         <XIcon         className=\"w-3.5 h-3.5\" />,\r\n  };\r\n\r\n  const handleProductClick = (id: string) => {\r\n    setSelectedId(id);\r\n    const el = document.getElementById('editorial-tryon');\r\n    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });\r\n  };\r\n\r\n  return (\r\n    <div className={`min-h-screen flex flex-col bg-[#fcfcfc] ${brand.landing_font || 'font-jakarta'} overflow-x-hidden ${isPreview ? 'p-0 h-auto' : ''}`} style={{ \"--primary\": primary, \"--secondary\": secondary, \"--secondary-10\": secondary + \"1a\", \"--secondary-20\": secondary + \"33\", \"--secondary-05\": secondary + \"0d\" } as React.CSSProperties}>\r\n      <EditorialHeader brand={brand} entries={entries} socialIcons={socialIcons} />\r\n      <EditorialHero brand={brand} />\r\n      \r\n      <main className=\"max-w-6xl mx-auto w-full px-4 md:px-6 py-12 md:py-20\">\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-start mb-16\">\r\n          {/* Catálogo Prioritario */}\r\n          <div className=\"order-2 lg:order-1\">\r\n            <div className=\"flex items-center justify-between border-b-2 border-black pb-4 mb-10\">\r\n              <h2 className=\"text-3xl font-black uppercase italic tracking-tighter\">Colección</h2>\r\n              <span className=\"text-[10px] font-black bg-black text-white px-3 py-1 uppercase\">{products?.length || 0} Items</span>\r\n            </div>\r\n            \r\n            <div className=\"grid grid-cols-2 xl:grid-cols-3 gap-6 md:gap-8\">\r\n              {products && Array.isArray(products) && products.map(p => (\r\n                <EditorialProductCard key={p.id} product={p} selected={selectedId === p.id} primaryColor={primary} onClick={() => handleProductClick(p.id)} />\r\n              ))}\r\n            </div>\r\n          </div>\r\n\r\n          {/* Probador Prioritario (Sidebar Sticky) */}\r\n          <aside className=\"order-1 lg:order-2\">\r\n            <div id=\"editorial-tryon\" className=\"lg:sticky lg:top-28\">\r\n              <div className={isPreview ? \"overflow-hidden bg-white\" : \"rounded-[3rem] overflow-hidden shadow-[0_40px_80px_-15px_rgba(0,0,0,0.15)] bg-white border border-gray-100\"}>"}],"details":{"status":"completed","exitCode":0,"durationMs":89,"aggregated":"export function TemplateEditorial({ brandSlug, brand, products, footerUrl, isPreview = false }: { brandSlug: string; brand: BrandData; products: ProductData[]; footerUrl?: string; isPreview?: boolean }) {\r\n  const primary = brand.social_links?._landing_primary || brand.primary_color || '#111111';\r\n  const secondary = brand.social_links?._landing_secondary || primary;\r\n  const [selectedId, setSelectedId] = useState<string | null>(products && products.length > 0 ? products[0].id : null);\r\n\r\n  const socialLinks = brand.social_links || {};\r\n  const entries = getVisibleSocialEntries(socialLinks);\r\n  const socialIcons: Record<string, React.ReactNode> = {\r\n    instagram: <InstagramIcon className=\"w-3.5 h-3.5\" />,\r\n    facebook:  <FacebookIcon  className=\"w-3.5 h-3.5\" />,\r\n    tiktok:    <TikTokIcon    className=\"w-3.5 h-3.5\" />,\r\n    youtube:   <YouTubeIcon   className=\"w-3.5 h-3.5\" />,\r\n    x:         <XIcon         className=\"w-3.5 h-3.5\" />,\r\n  };\r\n\r\n  const handleProductClick = (id: string) => {\r\n    setSelectedId(id);\r\n    const el = document.getElementById('editorial-tryon');\r\n    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });\r\n  };\r\n\r\n  return (\r\n    <div className={`min-h-screen flex flex-col bg-[#fcfcfc] ${brand.landing_font || 'font-jakarta'} overflow-x-hidden ${isPreview ? 'p-0 h-auto' : ''}`} style={{ \"--primary\": primary, \"--secondary\": secondary, \"--secondary-10\": secondary + \"1a\", \"--secondary-20\": secondary + \"33\", \"--secondary-05\": secondary + \"0d\" } as React.CSSProperties}>\r\n      <EditorialHeader brand={brand} entries={entries} socialIcons={socialIcons} />\r\n      <EditorialHero brand={brand} />\r\n      \r\n      <main className=\"max-w-6xl mx-auto w-full px-4 md:px-6 py-12 md:py-20\">\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-start mb-16\">\r\n          {/* Catálogo Prioritario */}\r\n          <div className=\"order-2 lg:order-1\">\r\n            <div className=\"flex items-center justify-between border-b-2 border-black pb-4 mb-10\">\r\n              <h2 className=\"text-3xl font-black uppercase italic tracking-tighter\">Colección</h2>\r\n              <span className=\"text-[10px] font-black bg-black text-white px-3 py-1 uppercase\">{products?.length || 0} Items</span>\r\n            </div>\r\n            \r\n            <div className=\"grid grid-cols-2 xl:grid-cols-3 gap-6 md:gap-8\">\r\n              {products && Array.isArray(products) && products.map(p => (\r\n                <EditorialProductCard key={p.id} product={p} selected={selectedId === p.id} primaryColor={primary} onClick={() => handleProductClick(p.id)} />\r\n              ))}\r\n            </div>\r\n          </div>\r\n\r\n          {/* Probador Prioritario (Sidebar Sticky) */}\r\n          <aside className=\"order-1 lg:order-2\">\r\n            <div id=\"editorial-tryon\" className=\"lg:sticky lg:top-28\">\r\n              <div className={isPreview ? \"overflow-hidden bg-white\" : \"rounded-[3rem] overflow-hidden shadow-[0_40px_80px_-15px_rgba(0,0,0,0.15)] bg-white border border-gray-100\"}>","cwd":"/home/travis/Lookitry/Lookitry"},"isError":false,"timestamp":1776034707140}}
