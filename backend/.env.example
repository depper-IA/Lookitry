# Server Configuration
PORT=3001
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=7d

# n8n Webhook Configuration
N8N_WEBHOOK_URL=
N8N_API_KEY=
N8N_TIMEOUT=90000
N8N_BEARER_TOKEN=
N8N_HEADER_NAME=Authorization

# OpenRouter API Configuration
OPENROUTER_API_KEY=

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Email Configuration (SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000

# CORS — dominio de producción (separar múltiples con coma)
CORS_ORIGIN=

# Wompi Payment Gateway (Colombia)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_ENABLED=false
