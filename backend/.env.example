# Server Configuration
PORT=3001
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=7d

# n8n Webhook Configuration
N8N_WEBHOOK_URL=
N8N_API_KEY=
N8N_TIMEOUT=90000
N8N_BEARER_TOKEN=
N8N_HEADER_NAME=Authorization

# OpenRouter API Configuration
OPENROUTER_API_KEY=
JULES_API_KEY=

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Email Configuration (SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000

# CORS — dominio de producción (separar múltiples con coma)
CORS_ORIGIN=

# Wompi Payment Gateway (Colombia)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
***REMOVED-SECRET***
WOMPI_ENABLED=false

# PayPal (Internacional)
# Si defines PAYPAL_CLIENT_ID/SECRET aquí, el backend los prioriza sobre payment_settings.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true
# Webhook ID (para verificación de firma). Requerido en producción.
PAYPAL_WEBHOOK_ID=

# Google OAuth (Google Sign-In)
# Obtener de: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Places API (Lead Generation)
# Obtener de: Google Cloud Console → APIs & Services → Credentials → API Key → Restrictions (Places API)
GOOGLE_PLACES_API_KEY=
