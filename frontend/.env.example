# API Configuration — URL del backend
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL base del frontend (para proxy de imágenes con URL absoluta)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Configuration (client-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# n8n descriptor webhook (opcional)
NEXT_PUBLIC_N8N_DESCRIPTOR_URL=

# Google OAuth (Google Sign-In)
# Obtener de: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudflare Turnstile (anti-spam en formularios)
# Obtener de: https://dash.cloudflare.com/turnstile → crear sitio → copiar Site Key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAABxxxxxxxxxxxxxxxxxxxxxxxxxxx
