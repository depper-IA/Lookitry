{
  "name": "Lookitry - NotebookLM Google Drive Sync",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "notebooklm-sync",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-receive",
      "name": "Webhook - Recibir archivos",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "typeVersion": 2,
      "webhookId": "notebooklm-sync"
    },
    {
      "parameters": {
        "jsCode": "// Parse Input - normaliza a array de archivos\nconst body = $input.first().json.body ?? $input.first().json;\nconst files = Array.isArray(body.files) ? body.files : [body];\n\nconst processed = files.map(f => ({\n  file_name: f.file_name || f.file_path?.split('/').pop() || 'unknown.md',\n  file_path: f.file_path || f.file_name || '',\n  content: f.content || '',\n  commit_sha: f.commit_sha || f.version || new Date().toISOString().replace(/[:.]/g, '-')\n})).filter(f => f.content.length > 0);\n\n\nif (processed.length === 0) {\n  throw new Error('No se proporcionaron archivos con contenido');\n}\n\nreturn processed.map(f => ({ json: f }));"
      },
      "id": "parse-input",
      "name": "Parse Input",
      "type": "n8n-nodes-base.code",
      "position": [450, 300],
      "typeVersion": 2
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "typeValidation": "strict" },
          "conditions": [
            {
              "id": "md-filter",
              "parameter1": "{{ $json.file_name }}",
              "parameter2": "",
              "type": "string",
              "operation": "endsWith",
              "value": ".md"
            }
          ]
        },
        "options": {}
      },
      "id": "filter-md",
      "name": "Filter .md files",
      "type": "n8n-nodes-base.if",
      "position": [650, 300],
      "typeVersion": 2.3
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "split-batches",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "position": [850, 300],
      "typeVersion": 4
    },
    {
      "parameters": {
        "jsCode": "// Prepare File Metadata\nconst data = $input.first().json;\nconst commitSha = data.commit_sha?.substring(0, 7) || 'unknown';\nconst baseName = data.file_name.replace('.md', '').replace(/[^a-zA-Z0-9_-]/g, '_');\nconst fileName = `${baseName}_${commitSha}.md`;\n// Folder ID de NotebookLM: https://drive.google.com/drive/u/1/folders/1EWF5O5458wC0zIdyAG7bOtfAhbEHzFB4\nconst folderId = '1EWF5O5458wC0zIdyAG7bOtfAhbEHzFB4';\nreturn [{ json: {\n  file_name: fileName,\n  original_name: data.file_name,\n  content: data.content,\n  folder_id: folderId\n} }];"
      },
      "id": "prepare-file",
      "name": "Prepare File Metadata",
      "type": "n8n-nodes-base.code",
      "position": [1050, 300],
      "typeVersion": 2
    },
    {
      "parameters": {
        "operation": "createFromText",
        "folderId": "{{ $json.folder_id }}",
        "fileName": "{{ $json.file_name }}",
        "fileContent": "{{ $json.content }}",
        "options": {
          "mimetype": "text/markdown"
        }
      },
      "id": "google-drive-create",
      "name": "Google Drive - Create File",
      "type": "n8n-nodes-base.googleDrive",
      "position": [1250, 300],
      "typeVersion": 4,
      "credentials": {
        "googleDriveOAuth2": {
          "id": "CREDENTIALS_ID_PLACEHOLDER",
          "name": "Google Drive API (OAuth2)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Log success\nconsole.log('Synced:', $input.first().json.file_name);"
      },
      "id": "log-success",
      "name": "Log Success",
      "type": "n8n-nodes-base.noOp",
      "position": [1450, 300]
    },
    {
      "parameters": {
        "respondWith": {
          "responseBody": "={{ { ok: true, synced_count: $input.length, timestamp: new Date().toISOString() } }}"
        },
        "options": {}
      },
      "id": "respond-success",
      "name": "Respond Success",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1650, 300],
      "typeVersion": 1.2
    },
    {
      "parameters": {
        "respondWith": {
          "responseBody": "={ ok: false, error: 'No .md files found', timestamp: new Date().toISOString() }"
        },
        "options": {}
      },
      "id": "respond-no-md",
      "name": "Respond - No .md files",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [850, 700],
      "typeVersion": 1.2
    }
  ],
  "connections": {
    "Webhook - Recibir archivos": { "main": [[{ "node": "Parse Input", "type": "main", "index": 0 }]] },
    "Parse Input": { "main": [[{ "node": "Filter .md files", "type": "main", "index": 0 }]] },
    "Filter .md files": {
      "main": [
        [{ "node": "Split In Batches", "type": "main", "index": 0 }],
        [{ "node": "Respond - No .md files", "type": "main", "index": 0 }]
      ]
    },
    "Split In Batches": { "main": [[{ "node": "Prepare File Metadata", "type": "main", "index": 0 }]] },
    "Prepare File Metadata": { "main": [[{ "node": "Google Drive - Create File", "type": "main", "index": 0 }]] },
    "Google Drive - Create File": { "main": [[{ "node": "Log Success", "type": "main", "index": 0 }]] },
    "Log Success": { "main": [[{ "node": "Respond Success", "type": "main", "index": 0 }]] }
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "America/Bogota"
  },
  "staticData": null,
  "tags": ["SaaS", "NotebookLM", "Google Drive"]
}
