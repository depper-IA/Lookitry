        "googleDriveOAuth2Api": {
          "id": "3JCkh9uFiAjVVrRA",
          "name": "Samwilkiedevs"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Combinar resultado de búsqueda con datos del archivo original\n// $input contiene el resultado de la búsqueda en Drive (puede estar vacío si no encontró)\n// Necesitamos recuperar los datos originales del nodo anterior\n\nconst searchResult = $input.first()?.json || {};\nconst fileData = $('Preparar archivo').first().json;\n\n// Si la búsqueda encontró un archivo, tendrá 'id'\nconst existingId = searchResult?.id || null;\n\nreturn [{ json: {\n  ...fileData,\n  existing_id: existingId,\n  file_found: !!existingId\n} }];"
      },
