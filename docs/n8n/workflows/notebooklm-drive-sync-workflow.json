      "id": "d9ecc211-491d-4652-95ac-2fc9fede902f",
      "name": "Webhook - Recibir archivos",
      "type": "n8n-nodes-base.webhook",
      "position": [480, 300],
      "typeVersion": 2,
      "webhookId": "notebooklm-sync"
    },
    {
      "parameters": {
        "jsCode": "// Parsear entrada del webhook\nconst body = $input.first().json.body ?? $input.first().json;\n\nconst files = Array.isArray(body.files) ? body.files : [body];\n\nconst processed = files.map(f => ({\n  file_name: f.file_name || f.file_path?.split('/').pop() || 'unknown.md',\n  file_path: f.file_path || f.file_name || '',\n  content: f.content || '',\n  commit_sha: f.commit_sha || f.version || new Date().toISOString()\n})).filter(f => f.content && String(f.file_name).toLowerCase().endsWith('.md'));\n\nif (processed.length === 0) {\n  throw new Error('No se proporcionaron archivos .md con contenido');\n}\n\nreturn processed.map(f => ({ json: f }));"
      },
      "id": "fe5766d0-673e-4ae3-870d-344075c7d066",
      "name": "Parsear y filtrar .md",
      "type": "n8n-nodes-base.code",
      "position": [700, 300],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "// Preparar nombre final del archivo para Drive\nconst data = $input.first().json;\nconst commitSha = String(data.commit_sha || new Date().toISOString());\nconst timestamp = commitSha.substring(0, 7);\nconst baseName = String(data.file_name).replace(/\\.md$/i, '');\n\nreturn [{ json: {\n  file_name: `${baseName}.md`,\n  search_name: `${baseName}.md`,\n  original_name: data.file_name,\n  content: data.content,\n  commit_sha: commitSha,\n  description: `Lookitry docs - Commit: ${commitSha}`\n} }];"
      },
      "id": "1128233f-5fd4-4e1d-9a7d-418e7255ad43",
      "name": "Preparar archivo",
      "type": "n8n-nodes-base.code",
      "position": [920, 300],
      "typeVersion": 2
    },
