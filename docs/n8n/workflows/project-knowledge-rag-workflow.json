{
  "name": "Lookitry - Project Knowledge RAG",
  "description": "Indexa documentación core (PRD, DESIGN, TECH_STACK, REGLAS) para RAG de agentes. Usa OpenAI embeddings.",
  "nodes": [
    {
      "id": "webhook-trigger",
      "name": "Webhook - Recibir documento",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "project-knowledge-rag",
        "responseMode": "responseNode",
        "options": {}
      },
      "typeVersion": 2,
      "webhookId": "project-knowledge-rag"
    },
    {
      "id": "validate-input",
      "name": "Validar y preparar datos",
      "type": "n8n-nodes-base.code",
      "position": [470, 300],
      "parameters": {
        "jsCode": "// Validar y normalizar entrada\nconst body = $input.first().json.body ?? $input.first().json;\n\nconst fileName = body.file_name;\nconst filePath = body.file_path || body.file_name;\nconst content = body.content;\nconst version = body.version || new Date().toISOString().split('T')[0];\n\nif (!fileName) throw new Error('file_name es requerido');\nif (!content) throw new Error('content es requerido');\n\n// Determinar tipo de documento\nlet docType = 'OTHER';\nconst upperFileName = fileName.toUpperCase();\nif (upperFileName.includes('PRD')) docType = 'PRD';\nelse if (upperFileName.includes('DESIGN')) docType = 'DESIGN';\nelse if (upperFileName.includes('TECH_STACK')) docType = 'TECH_STACK';\nelse if (upperFileName.includes('REGLAS')) docType = 'REGLAS';\nelse if (upperFileName.includes('CHANGELOG')) docType = 'CHANGELOG';\n\n\n// Calcular hash para detectar cambios\nconst contentHash = require('crypto')\n  .createHash('sha256')\n  .update(content)\n  .digest('hex');\n\n// Preparar texto para embedding (truncar si es muy largo)\nlet embedText = content;\nconst maxLength = 8000;\nif (embedText.length > maxLength) {\n  const chunkSize = Math.floor(maxLength / 2);\n  embedText = embedText.substring(0, chunkSize) + '\\n\\n...[truncado]...\\n\\n' + embedText.substring(embedText.length - chunkSize);\n}\n\nreturn [{ json: {\n  file_name: fileName,\n  file_path: filePath,\n  content: content,\n  content_hash: contentHash,\n  version: version,\n  doc_type: docType,\n  embedding_text: `[${docType}] ${fileName}\\n\\n${embedText}`\n} }];"
      },
      "typeVersion": 2
    },
    {
      "id": "check-existing",
      "name": "Supabase - Verificar existente",
      "type": "n8n-nodes-base.httpRequest",
      "position": [690, 300],
      "parameters": {
        "method": "GET",
        "url": "=https://vkdooutklowctuudjnkl.supabase.co/rest/v1/project_knowledge?file_path=eq.{{ $json.file_path }}&select=id,content_hash",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZrZG9vdXRrbG93Y3R1dWRqbmtsIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MDc2NTY2NSwiZXhwIjoyMDg2MzQxNjY1fQ.NxXV0Too3Iadb0FGuC8powPUuaMPiF1TKIUVtGMyFpg"
            },
            {
              "name": "Authorization",
              "value": "=Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZrZG9vdXRrbG93Y3R1dWRqbmtsIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MDc2NTY2NSwiZXhwIjoyMDg2MzQxNjY1fQ.NxXV0Too3Iadb0FGuC8powPUuaMPiF1TKIUVtGMyFpg"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "check-changes",
      "name": "¿Contenido cambió?",
      "type": "n8n-nodes-base.if",
      "position": [910, 300],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict" },
          "conditions": [
            {
              "id": "hash-check",
              "parameter1": "{{ $json.content_hash }}",
              "parameter2": "{{ $('Supabase - Verificar existente').first().json.content_hash }}",
              "type": "string",
              "operation": "notEquals"
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "openai-embedding",
      "name": "OpenAI - Generar embedding",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "position": [1130, 300],
      "parameters": {
        "resource": "embedding",
        "model": "text-embedding-3-small",
        "textToEmbed": "={{ $json.embedding_text }}"
      },
      "credentials": {
        "openAiApi": {
          "id": "1",
          "name": "OpenAI API"
        }
      }
    },
    {
      "id": "extract-embedding",
      "name": "Extraer embedding",
      "type": "n8n-nodes-base.code",
      "position": [1350, 300],
      "parameters": {
        "jsCode": "// Extraer embedding de OpenAI response\nconst response = $input.first().json;\nconst embedding = response.embedding || [];\n\nif (!Array.isArray(embedding) || embedding.length === 0) {\n  throw new Error('OpenAI no devolvió embedding válido');\n}\n\nconst data = $('Validar y preparar datos').first().json;\nreturn [{ json: {\n  ...data,\n  embedding: embedding\n} }];"
      },
      "typeVersion": 2
    },
    {
      "id": "supabase-upsert",
      "name": "Supabase - Upsert",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1570, 300],
      "parameters": {
        "method": "POST",
        "url": "=https://vkdooutklowctuudjnkl.supabase.co/rest/v1/rpc/upsert_project_knowledge",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZrZG9vdXRrbG93Y3R1dWRqbmtsIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MDc2NTY2NSwiZXhwIjoyMDg2MzQxNjY1fQ.NxXV0Too3Iadb0FGuC8powPUuaMPiF1TKIUVtGMyFpg" },
            { "name": "Authorization", "value": "=Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZrZG9vdXRrbG93Y3R1dWRqbmtsIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MDc2NTY2NSwiZXhwIjoyMDg2MzQxNjY1fQ.NxXV0Too3Iadb0FGuC8powPUuaMPiF1TKIUVtGMyFpg" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"p_file_name\": \"{{ $json.file_name }}\",\n  \"p_file_path\": \"{{ $json.file_path }}\",\n  \"p_content\": \"{{ $json.content }}\",\n  \"p_content_hash\": \"{{ $json.content_hash }}\",\n  \"p_embedding\": {{ JSON.stringify($json.embedding) }},\n  \"p_version\": \"{{ $json.version }}\",\n  \"p_doc_type\": \"{{ $json.doc_type }}\"\n}"
      }
    },
    {
      "id": "respond-ok",
      "name": "Responder OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1790, 300],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": true, \"file_name\": \"{{ $json.file_name }}\", \"doc_type\": \"{{ $json.doc_type }}\" }"
      },
      "typeVersion": 1
    },
    {
      "id": "respond-skipped",
      "name": "Responder sin cambios",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1130, 500],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": true, \"skipped\": true, \"file_name\": \"{{ $('Validar y preparar datos').first().json.file_name }}\" }"
      },
      "typeVersion": 1
    }
  ],
  "connections": {
