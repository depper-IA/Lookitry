    "OpenAI - Generar embedding": { "main": [[{ "node": "Extraer embedding", "type": "main", "index": 0 }]] },
    "Extraer embedding": { "main": [[{ "node": "Supabase - Upsert", "type": "main", "index": 0 }]] },
    "Supabase - Upsert": { "main": [[{ "node": "Responder OK", "type": "main", "index": 0 }]] }
  },
  "settings": {
