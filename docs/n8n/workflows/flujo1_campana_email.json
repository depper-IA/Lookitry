        "query": "SELECT id, nombre_empresa, nombre_contacto, email, ciudad, nicho, estado_lead FROM clientes WHERE campana_enviada = 'NO' AND email IS NOT NULL AND email != '' AND estado_lead != 'EMAIL_INVALIDO' AND estado_lead != 'BAJA' ORDER BY id ASC LIMIT 300;",
        "options": {}
      },
      "id": "supabase-fetch",
      "name": "🗄️ Supabase — Obtener 300 leads",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [460, 300],
      "credentials": {
