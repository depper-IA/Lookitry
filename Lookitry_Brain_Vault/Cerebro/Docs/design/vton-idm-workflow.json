        "responseBody": "={{ { success: true, imageUrl: $json.image_url, _meta: { model: $json._meta_model, executionId: $json._meta_execution_id, generatedAt: $json._meta_timestamp, brandId: $json.brand_id, productId: $json.product_id } } }}",
        "options": {
