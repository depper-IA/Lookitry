{
  "name": "Lookitry - Feedback Embedding RAG",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "feedback-embedding",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "3f0c3e65-8374-4763-bb22-9a980f42e62d",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        1792,
        512
      ],
      "webhookId": "feedback-embedding"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body ?? $input.first().json;\nconst feedbackId = body.feedback_id;\nconst errorType = body.error_type;\nconst description = body.description || '';\nconst productCategory = body.product_category || '';\nconst promptUsed = body.prompt_used || '';\nif (!feedbackId) throw new Error('feedback_id es requerido');\nif (!errorType) throw new Error('error_type es requerido');\nconst errorLabels = {\n  wrong_clothing_removed: 'Se eliminó ropa que debía conservarse',\n  wrong_clothing_kept: 'Se conservó ropa que debía eliminarse',\n  body_distortion: 'Distorsión corporal',\n  color_wrong: 'Color del producto incorrecto',\n  product_not_applied: 'El producto no se aplicó',\n  background_changed: 'El fondo cambió incorrectamente',\n  other: 'Otro error'\n};\nconst errorLabel = errorLabels[errorType] || errorType;\nconst parts = [\n  `Categoría de error: ${errorLabel}`,\n  productCategory ? `Tipo de producto: ${productCategory}` : '',\n  description ? `Descripción: ${description}` : '',\n  promptUsed ? `Prompt original: ${promptUsed}` : ''\n].filter(Boolean).join('. ');\nconst textToEmbed = `${errorLabel}. ${parts}`.slice(0, 1000);\nreturn [{ json: { feedback_id: feedbackId, error_type: errorType, error_label: errorLabel, product_category: productCategory, description, prompt_used: promptUsed, text_to_embed: textToEmbed } }];"
      },
      "id": "6161358b-62d3-45b0-b6dd-ed069f18cd70",
      "name": "Prepare Embedding Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2096,
        512
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/text-embedding-004:embedContent?key={{ $credentials.httpHeaderAuth.value }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"models/text-embedding-004\",\n  \"content\": { \"parts\": [{ \"text\": {{ JSON.stringify($json.text_to_embed) }} }] },\n  \"taskType\": \"RETRIEVAL_DOCUMENT\"\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "0f94b98f-35ca-4eed-b39a-459cbc2bedb4",
      "name": "Gemini Embedding",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        2400,
        512
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "GEMINI_API_CREDENTIAL_ID",
          "name": "Gemini API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\n\n// Formato Gemini: { embedding: { values: [...768 floats] } }\nconst embedding = response?.embedding?.values || [];\n\nif (!Array.isArray(embedding) || embedding.length === 0) {\n  throw new Error('Gemini no devolvió embedding válido. Response: ' + JSON.stringify(response).slice(0, 300));\n}\n\nif (embedding.length !== 768) {\n  throw new Error(`Dimensión incorrecta: esperadas 768, recibidas ${embedding.length}`);\n}\n\nconst data = $('Prepare Embedding Text').first().json;\n\nreturn [{ json: { feedback_id: data.feedback_id, embedding: embedding, dimensions: embedding.length } }];"
      },
      "id": "2b28660b-f122-4c1a-a989-efe48986635c",
      "name": "Extract Embedding",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2704,
        512
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"ok\": true,\n  \"feedback_id\": \"{{ $('Extract Embedding').first().json.feedback_id }}\",\n  \"dimensions\": {{ $('Extract Embedding').first().json.dimensions }}\n}",
        "options": {}
      },
      "id": "0d70e527-6887-43bd-8061-a8211e9b1161",
      "name": "Responder OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        3296,
        512
      ]
    },
    {
      "parameters": {
        "operation": "update",
        "tableId": "generation_feedback",
        "matchType": "allFilters",
        "filters": {
