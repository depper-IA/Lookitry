        "jsCode": "const body = $json.body ?? {};\nconst waMsg = body.whatsappInboundMessage ?? {};\n\n// Extraer phone del payload YCloud\nlet phone = waMsg.from ?? '';\nphone = phone.replace(/^whatsapp:/i, '').replace(/\\D/g, ''); // strip prefix y no-dígitos\nif (!phone) throw new Error('No se pudo extraer phone del payload YCloud');\n\nconst contact_name = waMsg.customerProfile?.name || 'Cliente';\nconst text = waMsg.text?.body || '';\nconst message_type = waMsg.type ?? '';\nconst to_number = waMsg.to ?? '';\nconst event_type = body.type ?? '';\n\nreturn [{ json: { phone, contact_name, text, message_type, to_number, event_type } }];"
      },
