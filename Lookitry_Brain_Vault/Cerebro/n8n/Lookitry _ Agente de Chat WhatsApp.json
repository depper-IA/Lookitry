    {
      "parameters": {
        "jsCode": "let rawOutput = $json.output;\n\n// Aseguramos que sea string\nrawOutput = String(rawOutput).trim();\n\n// Eliminamos bloques tipo ```json ... ```\nrawOutput = rawOutput\n  .replace(/```(json)?/gi, \"\") // elimina ```json o ``` \n  .replace(/```/g, \"\")         // elimina ``` finales\n  .trim();\n\n// Eliminamos caracteres de escape (\\n, \\t, etc.)\nrawOutput = rawOutput\n  .replace(/\\\\n/g, \"\")\n  .replace(/\\\\t/g, \"\")\n  .replace(/\\r/g, \"\")\n  .trim();\n\n// A veces vienen comillas escapadas dentro del texto; las corregimos si es necesario\nif (rawOutput.startsWith('\"') && rawOutput.endsWith('\"')) {\n  rawOutput = rawOutput.slice(1, -1);\n}\n\n// Mapa de etiquetas legacy a etiquetas Lookitry (por si el modelo devuelve etiquetas viejas)\nconst labelMap = {\n  'NUEVO LEAD': 'NUEVO_LEAD',\n  'EN PROCESO': 'EN_CONSULTA',\n  'DOCUMENTOS COMPLETOS': 'INTERESADO',\n  'EN ESTUDIO': 'INTERESADO',\n  'LLAMADA AGENDADA': 'DEMO_AGENDADA',\n  'DESCALIFICADO': 'DESCALIFICADO',\n  'DESCONOCIDO': 'DESCONOCIDO',\n  'NUEVO_LEAD': 'NUEVO_LEAD',\n  'EN_CONSULTA': 'EN_CONSULTA',\n  'INTERESADO': 'INTERESADO',\n  'DEMO_AGENDADA': 'DEMO_AGENDADA',\n  'CLIENTE': 'CLIENTE'\n};\n\n// Intentamos parsear\nlet parsed;\ntry {\n  parsed = JSON.parse(rawOutput);\n\n  const etiqueta = parsed.etiqueta?.trim() ?? 'DESCONOCIDO';\n  const etiquetaNormalizada = labelMap[etiqueta] ?? 'DESCONOCIDO';\n\n  return {\n    lead_status: etiquetaNormalizada,\n    bot_status: parsed.estado ?? 'activo'\n  };\n\n} catch (error) {\n  throw new Error(\"Error al parsear el JSON: \" + error.message + \"\\nContenido limpio: \" + rawOutput);\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
