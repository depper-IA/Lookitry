#!/usr/bin/env sh
# Husky pre-commit hook - runs frontend lint only
# Backend lint is skipped due to corrupted node_modules (missing report-translator.js)

echo "🔍 Verificando código..."

cd frontend && npm run lint
FRONTEND_LINT=$?
cd ..

if [ $FRONTEND_LINT -ne 0 ]; then
  echo "❌ Frontend lint falló"
  exit 1
fi

echo "✅ Lint pasado"
exit 0