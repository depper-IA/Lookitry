#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Verificando código..."

# Frontend lint
cd frontend && npm run lint
FRONTEND_LINT=$?
cd ..

# Backend lint
cd backend && npm run lint
BACKEND_LINT=$?
cd ..

# Frontend build
cd frontend && npm run build
FRONTEND_BUILD=$?
cd ..

# Backend build
cd backend && npm run build
BACKEND_BUILD=$?
cd ..

# Si algún check falla, salir con error
if [ $FRONTEND_LINT -ne 0 ]; then
  echo "❌ Frontend lint falló"
  exit 1
fi

if [ $BACKEND_LINT -ne 0 ]; then
  echo "❌ Backend lint falló"
  exit 1
fi

if [ $FRONTEND_BUILD -ne 0 ]; then
  echo "❌ Frontend build falló"
  exit 1
fi

if [ $BACKEND_BUILD -ne 0 ]; then
  echo "❌ Backend build falló"
  exit 1
fi

echo "✅ Todos los checks pasaron"
exit 0
