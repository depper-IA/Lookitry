{
  "userIgnore": [
    "node_modules",
    ".git",
    ".next",
    "dist",
    "build",
    "frontend",
    "backend",
    "scripts",
    "tmp",
    "idm-vton-api",
    "lookitry-woocommerce",
    ".husky",
    ".agents",
    ".flash",
    ".ruff_cache",
    "n8n",
    "supabase",
    "sammy",
    ".opencode",
    "**/*"
  ],
  "attachmentFolderPath": ".opencode/assets",
  "newFileLocation": "root",
  "useMarkdownLinks": true,
  "showLineNumber": true,
  "readableLineLength": true,
  "fileSortOrder": "alphabetical",
  "showUnsupportedFiles": false,
  "livePreview": true,
  "strictLineBreaks": true
}